        "custom_liquid": "{%- comment -%} SILKARA — PRODUCT PAGE (blush · skincare/haircare) {%- endcomment -%}\n{%- assign logo_url = \"https://cdn.shopify.com/s/files/1/0649/5702/2293/files/1780554076_WhatsApp_Image_2026-06-02_at_2.29.35_AM.jpg?v=1781280887\" -%}\n{%- assign p = product -%}\n{%- unless p -%}{%- assign p = collections.all.products.first -%}{%- endunless -%}\n{%- assign cur = p.selected_or_first_available_variant -%}\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Jost:wght@300;400;500&display=swap');\n\n  /* ── Reset overflow at root ── */\n  html, body { overflow-x: hidden; }\n\n  #sk {\n    --bg:#FFFFFF; --cream:#FBF3F1; --blush:#F6E6E3; --accent:#B26E73; --accent2:#CDA0A0;\n    --ink:#3E2F33; --text:#6E5F62; --line:#EEE0DC; --foot:#3E2F33;\n    --serif:'Cormorant Garamond',Georgia,'Times New Roman',serif;\n    --sans:'Jost',-apple-system,BlinkMacSystemFont,\"Segoe UI\",sans-serif;\n    font-family:var(--sans); color:var(--ink); line-height:1.7; background:var(--bg);\n    font-weight:300;\n    /* FIX: replaced 100vw / negative-margin trick with simple full-width */\n    width:100%; max-width:100%; overflow-x:hidden;\n    position:relative;\n  }\n  #sk * { box-sizing:border-box; }\n  #sk img { max-width:100%; display:block; }\n  #sk .wrap { max-width:1280px; margin:0 auto; padding:0 40px; }\n\n  /* Buttons */\n  #sk .btn { display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--accent); color:#fff; font-family:var(--sans); font-weight:500; font-size:12px; letter-spacing:2.5px; text-transform:uppercase; border:none; border-radius:2px; padding:17px 42px; cursor:pointer; text-decoration:none; transition:background .25s,transform .2s; width:100%; }\n  #sk .btn:hover { background:var(--ink); transform:translateY(-1px); }\n  #sk .btn[disabled] { background:#D6BEBE; cursor:not-allowed; transform:none; }\n\n  /* Typography helpers */\n  #sk .eyebrow { font-size:11px; font-weight:500; letter-spacing:4px; text-transform:uppercase; color:var(--accent); }\n  #sk h2.disp { font-family:var(--serif); font-weight:500; font-size:clamp(28px,3.6vw,42px); line-height:1.14; letter-spacing:.5px; color:var(--ink); margin:0; }\n  #sk .sect { padding:90px 0; }\n  #sk .head { max-width:620px; margin:0 auto 50px; text-align:center; }\n  #sk .head .eyebrow { display:block; margin-bottom:14px; }\n  #sk .head p { color:var(--text); margin:14px auto 0; font-size:16px; }\n\n  /* Announcement bar */\n  #sk .ann { background:var(--ink); color:#F6EAE7; overflow:hidden; }\n  #sk .ann-track { display:flex; gap:64px; white-space:nowrap; padding:11px 0; animation:sk-ann 30s linear infinite; }\n  #sk .ann:hover .ann-track { animation-play-state:paused; }\n  #sk .ann span { font-size:11px; font-weight:400; letter-spacing:2.5px; text-transform:uppercase; }\n  @keyframes sk-ann { from{transform:translateX(0);} to{transform:translateX(-50%);} }\n\n  /* Header */\n  #sk .hdr { background:rgba(255,255,255,.92); backdrop-filter:blur(10px); border-bottom:1px solid var(--line); position:sticky; top:0; z-index:40; width:100%; }\n  #sk .hdr-in { display:grid; grid-template-columns:1fr auto 1fr; align-items:center; padding:16px 40px; max-width:1280px; margin:0 auto; }\n  #sk .hdr-nav { display:flex; gap:34px; }\n  #sk .hdr-nav a { color:var(--ink); text-decoration:none; font-size:12px; font-weight:400; letter-spacing:2px; text-transform:uppercase; transition:color .2s; }\n  #sk .hdr-nav a:hover { color:var(--accent); }\n  #sk .hdr-logo { justify-self:center; text-decoration:none; display:flex; flex-direction:column; align-items:center; line-height:1; }\n  #sk .hdr-logo .wm { font-family:var(--serif); font-size:30px; font-weight:600; color:var(--ink); letter-spacing:6px; text-indent:6px; }\n  #sk .hdr-logo .sub { font-size:8px; font-weight:500; color:var(--accent2); letter-spacing:5px; text-indent:5px; margin-top:3px; }\n  #sk .hdr-logo img { height:66px; width:auto; max-width:180px; }\n  #sk .hdr-act { justify-self:end; display:flex; align-items:center; gap:22px; }\n  #sk .hdr-act a, #sk .hdr-act button { background:none; border:none; cursor:pointer; color:var(--ink); text-decoration:none; display:flex; padding:0; }\n  #sk .hdr-act svg { width:20px; height:20px; stroke-width:1.4; }\n  #sk .hdr-cart { position:relative; }\n  #sk .hdr-count { position:absolute; top:-8px; right:-10px; background:var(--accent); color:#fff; font-size:10px; font-weight:500; min-width:17px; height:17px; border-radius:9px; display:flex; align-items:center; justify-content:center; padding:0 4px; }\n\n  /* Breadcrumb */\n  #sk .crumb { font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--accent2); padding:26px 0 0; }\n  #sk .crumb a { color:var(--accent2); text-decoration:none; }\n  #sk .crumb a:hover { color:var(--accent); }\n\n  /* Product layout */\n  #sk .pc { display:grid; grid-template-columns:1.05fr .95fr; gap:64px; padding:26px 0 80px; align-items:start; }\n  /* FIX: prevent grid children from overflowing */\n  #sk .pc > * { min-width:0; }\n\n  /* Gallery */\n  #sk .gallery .main { border-radius:3px; background:var(--cream); aspect-ratio:4/5; object-fit:cover; width:100%; }\n  #sk .thumbs { display:flex; gap:12px; margin-top:14px; flex-wrap:wrap; }\n  #sk .thumbs img { width:78px; height:78px; object-fit:cover; border-radius:2px; border:1px solid var(--line); cursor:pointer; background:var(--cream); transition:border-color .2s; }\n  #sk .thumbs img.active { border-color:var(--accent); }\n\n  /* Product info */\n  #sk .info { padding-top:8px; min-width:0; }\n  #sk .info .rate { font-size:12px; letter-spacing:1.5px; color:var(--accent2); }\n  #sk .info .rate .st { color:#D98E8E; letter-spacing:2px; }\n  #sk .pc h1 { font-family:var(--serif); font-size:clamp(28px,4vw,48px); font-weight:500; line-height:1.08; margin:12px 0 14px; letter-spacing:.5px; word-break:break-word; }\n  #sk .price-row { display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; margin-bottom:8px; }\n  #sk .price { font-family:var(--serif); font-size:32px; color:var(--accent); }\n  #sk .compare { font-size:18px; color:var(--accent2); text-decoration:line-through; }\n  #sk .sale-badge { font-size:10px; letter-spacing:1.5px; text-transform:uppercase; background:var(--accent); color:#fff; padding:5px 10px; border-radius:2px; }\n  #sk .pc-desc { color:var(--text); font-size:16px; margin:16px 0 22px; }\n  #sk .hr { height:1px; background:var(--line); border:none; margin:22px 0; }\n\n  /* Countdown */\n  #sk .countdown { display:flex; align-items:center; gap:16px; flex-wrap:wrap; margin:18px 0; }\n  #sk .countdown .lab { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--text); }\n  #sk .countdown .clk { display:flex; align-items:center; gap:8px; }\n  #sk .countdown .u { background:var(--cream); border:1px solid var(--line); border-radius:2px; min-width:50px; padding:8px 6px; text-align:center; }\n  #sk .countdown .u .n { font-family:var(--serif); font-size:22px; line-height:1; color:var(--ink); }\n  #sk .countdown .u .c { font-size:9px; letter-spacing:1px; text-transform:uppercase; color:var(--accent2); margin-top:3px; }\n\n  /* Options / variants */\n  #sk .opt { margin:18px 0; }\n  #sk .opt label { display:block; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--text); margin-bottom:9px; }\n  #sk .swatches { display:flex; flex-wrap:wrap; gap:9px; }\n  #sk .swatch { border:1px solid var(--line); border-radius:2px; padding:10px 18px; cursor:pointer; font-size:13px; letter-spacing:.5px; background:#fff; color:var(--ink); transition:.2s; }\n  #sk .swatch.active { border-color:var(--accent); background:var(--cream); }\n\n  /* Buy row */\n  #sk .buy { display:flex; gap:14px; align-items:stretch; margin-top:6px; }\n  #sk .qty { display:inline-flex; align-items:center; border:1px solid var(--line); border-radius:2px; flex-shrink:0; }\n  #sk .qty button { width:44px; height:52px; border:none; background:#fff; color:var(--ink); font-size:18px; cursor:pointer; }\n  #sk .qty input { width:42px; height:52px; text-align:center; border:none; background:#fff; color:var(--ink); font-size:15px; -moz-appearance:textfield; }\n  #sk .qty input::-webkit-outer-spin-button, #sk .qty input::-webkit-inner-spin-button { -webkit-appearance:none; margin:0; }\n  #sk .buy .btn { flex:1; }\n\n  /* Reassurances */\n  #sk .reassure { display:flex; flex-wrap:wrap; gap:18px; margin-top:20px; }\n  #sk .reassure .r { display:flex; align-items:center; gap:8px; font-size:12px; letter-spacing:.5px; color:var(--text); }\n  #sk .reassure svg { width:17px; height:17px; stroke:var(--accent); stroke-width:1.5; fill:none; flex-shrink:0; }\n\n  /* Benefits grid */\n  #sk .benefits { display:grid; grid-template-columns:repeat(2,1fr); gap:1px; background:var(--line); border:1px solid var(--line); border-radius:3px; overflow:hidden; max-width:1000px; margin:0 auto; }\n  #sk .bcard { background:#fff; padding:34px 30px; min-width:0; }\n  #sk .bcard .bi { font-size:26px; margin-bottom:12px; }\n  #sk .bcard h3 { font-family:var(--serif); font-size:22px; font-weight:500; margin:0 0 6px; color:var(--ink); }\n  #sk .bcard p { margin:0; font-size:14px; color:var(--text); line-height:1.65; }\n\n  /* Editorial section */\n  #sk .ed { display:grid; grid-template-columns:1fr 1fr; align-items:stretch; }\n  #sk .ed > * { min-width:0; }\n  #sk .ed .media { background:var(--cream); min-height:520px; overflow:hidden; }\n  #sk .ed .media img { width:100%; height:100%; object-fit:cover; }\n  #sk .ed .media .ph { width:100%; height:100%; min-height:520px; display:flex; align-items:center; justify-content:center; font-size:72px; background:linear-gradient(140deg,#F6E6E3,#e3c2bd); }\n  #sk .ed .copy { background:var(--blush); display:flex; flex-direction:column; justify-content:center; padding:clamp(30px,6vw,90px); }\n  #sk .ed .copy h2 { margin:14px 0 22px; }\n  #sk .steps { list-style:none; padding:0; margin:0; counter-reset:s; }\n  #sk .steps li { display:flex; gap:16px; margin-bottom:20px; font-size:15px; color:var(--ink); align-items:flex-start; }\n  #sk .steps li::before { counter-increment:s; content:\"0\" counter(s); font-family:var(--serif); font-size:20px; color:var(--accent); min-width:30px; }\n  #sk .note { margin-top:8px; font-size:13px; color:var(--text); }\n\n  /* Comparison table */\n  #sk .cmp { max-width:760px; margin:0 auto; border:1px solid var(--line); border-radius:3px; overflow:hidden; }\n  #sk .cmp-row { display:grid; grid-template-columns:1fr 130px 130px; align-items:center; border-bottom:1px solid var(--line); }\n  #sk .cmp-row > * { min-width:0; }\n  #sk .cmp-row:last-child { border-bottom:none; }\n  #sk .cmp-row.h { background:var(--cream); }\n  #sk .cmp-row.h > div { font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--text); padding:16px; text-align:center; }\n  #sk .cmp-row.h .us { color:var(--accent); font-weight:500; }\n  #sk .cmp-row .lbl { padding:16px 20px; font-size:14px; color:var(--ink); }\n  #sk .cmp-row .v { text-align:center; padding:16px; font-size:15px; }\n  #sk .cmp-row .v.us { background:var(--cream); color:var(--accent); }\n  #sk .cmp-row .v.no { color:var(--accent2); }\n\n  /* FAQ */\n  #sk .faq { max-width:760px; margin:0 auto; }\n  #sk .faq-item { border-bottom:1px solid var(--line); }\n  #sk .faq-q { width:100%; text-align:left; background:none; border:none; padding:24px 0; font-family:var(--serif); font-size:21px; font-weight:500; cursor:pointer; display:flex; justify-content:space-between; align-items:center; color:var(--ink); gap:20px; }\n  #sk .faq-q .pl { font-size:20px; color:var(--accent); transition:transform .2s; font-family:var(--sans); flex-shrink:0; }\n  #sk .faq-a { padding:0; max-height:0; overflow:hidden; transition:max-height .25s,padding .25s; color:var(--text); font-size:15px; }\n  #sk .faq-item.open .faq-a { padding:0 0 24px; max-height:420px; }\n  #sk .faq-item.open .pl { transform:rotate(45deg); }\n\n  /* Sticky bar */\n  #sk .sticky { position:fixed; left:0; right:0; bottom:0; z-index:50; background:rgba(255,255,255,.97); backdrop-filter:blur(8px); border-top:1px solid var(--line); transform:translateY(110%); transition:transform .3s; width:100%; }\n  #sk .sticky.show { transform:translateY(0); }\n  #sk .sticky-in { display:flex; align-items:center; justify-content:space-between; gap:16px; padding:14px 40px; max-width:1280px; margin:0 auto; }\n  #sk .sticky .sn { font-family:var(--serif); font-size:20px; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }\n  #sk .sticky .sp { color:var(--accent); margin-left:10px; }\n  #sk .sticky .btn { width:auto; padding:14px 34px; flex-shrink:0; }\n\n  /* Cart drawer */\n  #sk .cd-ov { position:fixed; inset:0; background:rgba(62,47,51,.5); z-index:9990; opacity:0; visibility:hidden; transition:opacity .3s; }\n  #sk .cd-ov.open { opacity:1; visibility:visible; }\n  #sk .cd { position:fixed; top:0; right:0; bottom:0; width:420px; max-width:92vw; background:#fff; z-index:9991; display:flex; flex-direction:column; transform:translateX(100%); transition:transform .35s cubic-bezier(.4,0,.2,1); }\n  #sk .cd.open { transform:translateX(0); }\n  #sk .cd-head { display:flex; align-items:center; justify-content:space-between; padding:24px; border-bottom:1px solid var(--line); }\n  #sk .cd-head h3 { margin:0; font-size:12px; font-weight:500; color:var(--ink); text-transform:uppercase; letter-spacing:2.5px; }\n  #sk .cd-close { background:none; border:none; font-size:26px; cursor:pointer; color:var(--ink); line-height:1; }\n  #sk .cd-items { flex:1; overflow-y:auto; padding:18px 24px; }\n  #sk .cd-item { display:flex; gap:14px; padding:16px 0; border-bottom:1px solid var(--line); }\n  #sk .cd-item img { width:66px; height:66px; object-fit:cover; border-radius:2px; background:var(--cream); flex-shrink:0; }\n  #sk .cd-title { font-family:var(--serif); font-size:17px; color:var(--ink); text-decoration:none; }\n  #sk .cd-qty { display:inline-flex; align-items:center; border:1px solid var(--line); border-radius:2px; margin-top:8px; }\n  #sk .cd-qty button { width:28px; height:28px; border:none; background:none; cursor:pointer; font-size:15px; color:var(--ink); }\n  #sk .cd-qty span { width:30px; text-align:center; font-size:13px; color:var(--ink); }\n  #sk .cd-rm { background:none; border:none; color:#B7A6A2; font-size:11px; letter-spacing:1px; cursor:pointer; text-decoration:underline; padding:0; margin-top:6px; }\n  #sk .cd-foot { padding:24px; border-top:1px solid var(--line); }\n  #sk .cd-sub { display:flex; justify-content:space-between; font-size:15px; margin-bottom:6px; color:var(--ink); }\n  #sk .cd-sub b { font-family:var(--serif); font-size:20px; font-weight:500; }\n  #sk .cd-co { display:block; text-align:center; background:var(--accent); color:#fff; border-radius:2px; padding:16px; font-size:12px; letter-spacing:2.5px; text-transform:uppercase; text-decoration:none; margin-top:8px; }\n  #sk .cd-co:hover { background:var(--ink); }\n  #sk .cd-empty { text-align:center; color:#B7A6A2; padding:70px 20px; font-size:14px; }\n\n  /* ── RESPONSIVE ── */\n  @media(max-width:860px) {\n    #sk .wrap { padding:0 20px; }\n    #sk .hdr-in { padding:14px 20px; }\n    #sk .hdr-nav { display:none; }\n    #sk .pc { grid-template-columns:1fr; gap:30px; }\n    #sk .ed { grid-template-columns:1fr; }\n    #sk .ed .media, #sk .ed .media .ph { min-height:320px; }\n    #sk .sticky-in { padding:14px 20px; }\n    #sk .sticky .sn { display:none; }\n  }\n  @media(max-width:760px) {\n    #sk .benefits { grid-template-columns:1fr; }\n  }\n  @media(max-width:680px) {\n    #sk .benefits { grid-template-columns:1fr; }\n    #sk .cmp-row { grid-template-columns:1fr 70px 70px; }\n    #sk .cmp-row .lbl { font-size:13px; padding:14px 12px; }\n  }\n  @media(max-width:480px) {\n    #sk .hdr-logo img { height:50px; }\n    #sk .pc h1 { font-size:28px; }\n    #sk .buy { flex-wrap:wrap; }\n    #sk .buy .btn { width:100%; }\n    #sk .countdown .clk { gap:6px; }\n    #sk .countdown .u { min-width:44px; }\n  }\n</style>\n\n<div id=\"sk\">\n\n  <div class=\"ann\"><div class=\"ann-track\">\n    {%- for i in (1..2) -%}\n      <span>Premium skincare &amp; haircare</span><span>Cash on delivery available</span><span>Gentle, effective formulas</span><span>Loved by our customers</span>\n    {%- endfor -%}\n  </div></div>\n\n  <header class=\"hdr\"><div class=\"hdr-in\">\n    <nav class=\"hdr-nav\">\n      <a href=\"{{ routes.root_url }}\">Home</a>\n      <a href=\"{{ routes.all_products_collection_url }}\">Shop</a>\n      <a href=\"/pages/about\">About</a>\n    </nav>\n    <a class=\"hdr-logo\" href=\"{{ routes.root_url }}\">{%- if logo_url != blank -%}<img src=\"{{ logo_url }}\" alt=\"Silkara\">{%- elsif shop.brand.logo -%}<img src=\"{{ shop.brand.logo | image_url: width: 360 }}\" alt=\"{{ shop.name | escape }}\">{%- else -%}<span class=\"wm\">SILKARA</span><span class=\"sub\">SKIN &amp; HAIR</span>{%- endif -%}</a>\n    <div class=\"hdr-act\">\n      <a href=\"{{ routes.search_url }}\" aria-label=\"Search\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"m21 21-4.3-4.3\"/></svg></a>\n      <a href=\"{{ routes.account_url }}\" aria-label=\"Account\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 21c0-4 4-6 8-6s8 2 8 6\"/></svg></a>\n      <button class=\"hdr-cart\" onclick=\"skCartOpen()\" aria-label=\"Cart\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z\"/><path d=\"M3 6h18\"/><path d=\"M16 10a4 4 0 0 1-8 0\"/></svg><span class=\"hdr-count\" id=\"sk-count\">{{ cart.item_count }}</span></button>\n    </div>\n  </div></header>\n\n  <div class=\"wrap\">\n    <div class=\"crumb\"><a href=\"{{ routes.root_url }}\">Home</a> · <a href=\"{{ routes.all_products_collection_url }}\">Shop</a> · {{ p.title }}</div>\n    <div class=\"pc\">\n      <div class=\"gallery\">\n        {%- if p.featured_image -%}\n          <img class=\"main\" id=\"sk-main\" src=\"{{ p.featured_image | image_url: width:1000 }}\" alt=\"{{ p.title | escape }}\">\n          {%- if p.images.size > 1 -%}\n            <div class=\"thumbs\">\n              {%- for img in p.images limit:6 -%}\n                <img src=\"{{ img | image_url: width:160 }}\" class=\"{% if forloop.first %}active{% endif %}\" onclick=\"skSwap('{{ img | image_url: width:1000 }}',this)\" alt=\"\">\n              {%- endfor -%}\n            </div>\n          {%- endif -%}\n        {%- else -%}<div class=\"main\" style=\"display:flex;align-items:center;justify-content:center;color:#B7A6A2;font-size:42px;\">🌸</div>{%- endif -%}\n      </div>\n\n      <div class=\"info\">\n        <div class=\"rate\"><span class=\"st\">★★★★★</span> &nbsp;4.9 · loved by our customers</div>\n        <h1>{{ p.title | default: 'Silkara' }}</h1>\n\n        {%- if p -%}\n        {%- assign hh = p.handle -%}\n        {%- form 'product', p, id:'sk-form' -%}\n          <div class=\"price-row\">\n            <span class=\"price\" id=\"sk-price\">{{ cur.price | money }}</span>\n            {%- if cur.compare_at_price > cur.price -%}\n              <span class=\"compare\">{{ cur.compare_at_price | money }}</span>\n              {%- assign diff = cur.compare_at_price | minus: cur.price -%}\n              {%- assign pct = diff | times:100 | divided_by: cur.compare_at_price -%}\n              <span class=\"sale-badge\">Save {{ pct }}%</span>\n            {%- endif -%}\n          </div>\n          {%- if hh contains 'hair' or hh contains 'mask' or hh contains 'karseell' -%}\n            <p class=\"pc-desc\">A rich, collagen-infused repair mask that deeply nourishes dry, damaged hair — leaving it noticeably softer, smoother and shinier after just one use.</p>\n          {%- elsif hh contains 'jelly' or hh contains 'cream' or hh contains 'medicube' or hh contains 'collagen' -%}\n            <p class=\"pc-desc\">A bouncy collagen jelly cream that drenches skin in lightweight hydration — for a plump, dewy, glass-skin glow that lasts all day.</p>\n          {%- else -%}\n            <p class=\"pc-desc\">{{ p.description | strip_html | strip_newlines | replace: '        ', ' ' | replace: '      ', ' ' | replace: '    ', ' ' | replace: '   ', ' ' | replace: '  ', ' ' | replace: '  ', ' ' | strip | truncatewords: 42 | default: 'Premium skincare and haircare crafted to make self-care feel effortless and beautiful.' }}</p>\n          {%- endif -%}\n\n          <hr class=\"hr\">\n\n          <div class=\"countdown\">\n            <span class=\"lab\">Offer ends in</span>\n            <div class=\"clk\">\n              <div class=\"u\"><div class=\"n\" id=\"sk-cd-h\">00</div><div class=\"c\">Hrs</div></div>\n              <div class=\"u\"><div class=\"n\" id=\"sk-cd-m\">00</div><div class=\"c\">Min</div></div>\n              <div class=\"u\"><div class=\"n\" id=\"sk-cd-s\">00</div><div class=\"c\">Sec</div></div>\n            </div>\n          </div>\n\n          {%- unless p.has_only_default_variant -%}\n            {%- for opt in p.options_with_values -%}\n              <div class=\"opt\"><label>{{ opt.name }}</label>\n                <div class=\"swatches\">\n                  {%- for val in opt.values -%}\n                    <div class=\"swatch {% if opt.selected_value == val %}active{% endif %}\" data-value=\"{{ val | escape }}\" onclick=\"skOpt(this,{{ forloop.parentloop.index0 }})\">{{ val }}</div>\n                  {%- endfor -%}\n                </div>\n              </div>\n            {%- endfor -%}\n          {%- endunless -%}\n          <select name=\"id\" id=\"sk-sel\" style=\"display:none;\">\n            {%- for v in p.variants -%}\n              <option value=\"{{ v.id }}\" {% if v == cur %}selected{% endif %} {% unless v.available %}disabled{% endunless %} data-price=\"{{ v.price | money }}\" {% for o in v.options %}data-opt{{ forloop.index0 }}=\"{{ o | escape }}\"{% endfor %}>{{ v.title }}</option>\n            {%- endfor -%}\n          </select>\n\n          <div class=\"opt\"><label>Quantity</label>\n            <div class=\"buy\">\n              <div class=\"qty\"><button type=\"button\" onclick=\"skQty(-1)\">−</button><input type=\"number\" name=\"quantity\" id=\"sk-qty\" value=\"1\" min=\"1\"><button type=\"button\" onclick=\"skQty(1)\">+</button></div>\n              <button type=\"submit\" class=\"btn\" id=\"sk-atc\" {% unless cur.available %}disabled{% endunless %}>{% if cur.available %}Add to Cart{% else %}Sold Out{% endif %}</button>\n            </div>\n          </div>\n\n          <div class=\"reassure\">\n            <span class=\"r\"><svg viewBox=\"0 0 24 24\"><path d=\"M20 6 9 17l-5-5\"/></svg> Gentle &amp; effective</span>\n            <span class=\"r\"><svg viewBox=\"0 0 24 24\"><rect x=\"2\" y=\"6\" width=\"20\" height=\"12\" rx=\"2\"/><path d=\"M2 10h20\"/></svg> Cash on delivery</span>\n            <span class=\"r\"><svg viewBox=\"0 0 24 24\"><path d=\"M20 6 9 17l-5-5\"/></svg> Loved by customers</span>\n          </div>\n        {%- endform -%}\n        {%- else -%}\n          <p class=\"pc-desc\">This product isn't published yet — add it in your Shopify admin and it will appear here automatically.</p>\n          <a class=\"btn\" href=\"{{ routes.all_products_collection_url }}\" style=\"margin-top:12px;\">Browse Products</a>\n        {%- endif -%}\n      </div>\n    </div>\n  </div>\n\n  <section class=\"sect\" style=\"background:var(--cream);\"><div class=\"wrap\">\n    {%- assign h = p.handle -%}\n    {%- if h contains 'hair' or h contains 'mask' or h contains 'karseell' -%}\n      <div class=\"head\"><span class=\"eyebrow\">Repair &amp; Shine</span><h2 class=\"disp\">Why you'll love it</h2><p>Salon-level hair repair at home — collagen-rich care for softer, healthier, glossier hair.</p></div>\n      <div class=\"benefits\">\n        <div class=\"bcard\"><div class=\"bi\">💧</div><h3>Deep Nourishment</h3><p>Collagen &amp; amino acids restore moisture to dry, damaged strands.</p></div>\n        <div class=\"bcard\"><div class=\"bi\">✨</div><h3>Smooth &amp; Shiny</h3><p>Tames frizz and adds a healthy, mirror-like shine.</p></div>\n        <div class=\"bcard\"><div class=\"bi\">🌿</div><h3>Stronger Hair</h3><p>Helps reduce breakage so hair looks fuller and feels softer.</p></div>\n        <div class=\"bcard\"><div class=\"bi\">🎀</div><h3>For All Hair Types</h3><p>Ideal for dry, color-treated or heat-damaged hair.</p></div>\n      </div>\n    {%- elsif h contains 'jelly' or h contains 'cream' or h contains 'medicube' or h contains 'collagen' -%}\n      <div class=\"head\"><span class=\"eyebrow\">Plump &amp; Glow</span><h2 class=\"disp\">Why you'll love it</h2><p>A collagen jelly cream that gives skin a bouncy, dewy, glass-skin finish.</p></div>\n      <div class=\"benefits\">\n        <div class=\"bcard\"><div class=\"bi\">💗</div><h3>Collagen Boost</h3><p>Helps skin look plump, firm and bouncy.</p></div>\n        <div class=\"bcard\"><div class=\"bi\">💧</div><h3>Deep Hydration</h3><p>Lightweight jelly drenches skin in lasting moisture.</p></div>\n        <div class=\"bcard\"><div class=\"bi\">🌸</div><h3>Dewy Glow</h3><p>Leaves a fresh, glass-skin glow — never greasy.</p></div>\n        <div class=\"bcard\"><div class=\"bi\">🛡️</div><h3>Barrier Support</h3><p>Helps strengthen and soothe the skin barrier.</p></div>\n      </div>\n    {%- else -%}\n      <div class=\"head\"><span class=\"eyebrow\">About</span><h2 class=\"disp\">{{ p.title }}</h2></div>\n      <div style=\"max-width:760px;margin:0 auto;text-align:center;color:var(--text);font-size:16px;\">{{ p.description }}</div>\n    {%- endif -%}\n  </div></section>\n\n  <section class=\"ed\">\n    <div class=\"media\">{%- if p.images[1] -%}<img src=\"{{ p.images[1] | image_url: width:1100 }}\" alt=\"\">{%- elsif p.featured_image -%}<img src=\"{{ p.featured_image | image_url: width:1100 }}\" alt=\"\">{%- else -%}<div class=\"ph\">🌸</div>{%- endif -%}</div>\n    <div class=\"copy\">\n      <span class=\"eyebrow\">The Ritual</span>\n      <h2 class=\"disp\">How to use</h2>\n      {%- if h contains 'hair' or h contains 'mask' or h contains 'karseell' -%}\n        <ul class=\"steps\">\n          <li>Shampoo and gently towel-dry your hair.</li>\n          <li>Apply the mask from mid-length to ends.</li>\n          <li>Leave on for 5–10 minutes to absorb.</li>\n          <li>Rinse thoroughly. Use 2–3× a week.</li>\n        </ul>\n        <p class=\"note\">Avoid the scalp roots for fine hair. For best results, use consistently.</p>\n      {%- elsif h contains 'jelly' or h contains 'cream' or h contains 'medicube' or h contains 'collagen' -%}\n        <ul class=\"steps\">\n          <li>Cleanse and tone your skin.</li>\n          <li>Apply your serum or essence (optional).</li>\n          <li>Smooth a layer of jelly cream over face &amp; neck.</li>\n          <li>Use morning and night as the last step.</li>\n        </ul>\n        <p class=\"note\">Patch-test first if your skin is sensitive. For external use only.</p>\n      {%- else -%}\n        <ul class=\"steps\">\n          <li>Start with clean skin or hair.</li>\n          <li>Apply an even amount to the area.</li>\n          <li>Massage in gently and let it absorb.</li>\n          <li>Use regularly for best results.</li>\n        </ul>\n        <p class=\"note\">Follow the directions included with your product.</p>\n      {%- endif -%}\n    </div>\n  </section>\n\n  <section class=\"sect\"><div class=\"wrap\">\n    <div class=\"head\"><span class=\"eyebrow\">The Difference</span><h2 class=\"disp\">Silkara vs others</h2></div>\n    <div class=\"cmp\">\n      <div class=\"cmp-row h\"><div></div><div class=\"us\">Silkara</div><div>Others</div></div>\n      <div class=\"cmp-row\"><div class=\"lbl\">Premium, proven formulas</div><div class=\"v us\">✓</div><div class=\"v no\">✕</div></div>\n      <div class=\"cmp-row\"><div class=\"lbl\">Gentle &amp; effective</div><div class=\"v us\">✓</div><div class=\"v no\">✕</div></div>\n      <div class=\"cmp-row\"><div class=\"lbl\">Beautifully easy to use</div><div class=\"v us\">✓</div><div class=\"v no\">✕</div></div>\n      <div class=\"cmp-row\"><div class=\"lbl\">Cash on delivery</div><div class=\"v us\">✓</div><div class=\"v no\">✕</div></div>\n      <div class=\"cmp-row\"><div class=\"lbl\">Friendly local support</div><div class=\"v us\">✓</div><div class=\"v no\">✕</div></div>\n    </div>\n  </div></section>\n\n  <section class=\"sect\" style=\"background:var(--cream);\"><div class=\"wrap\">\n    <div class=\"head\"><span class=\"eyebrow\">Good to Know</span><h2 class=\"disp\">Questions, answered</h2></div>\n    <div class=\"faq\">\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"skFaq(this)\">Is it gentle and safe? <span class=\"pl\">+</span></button><div class=\"faq-a\">Yes — Silkara products are designed to be gentle and effective. Follow the included directions and patch-test skincare if you have sensitive skin.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"skFaq(this)\">How do I use it? <span class=\"pl\">+</span></button><div class=\"faq-a\">See the \"How to use\" steps above — it only takes a few minutes. Full directions are included with your product.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"skFaq(this)\">How long does delivery take? <span class=\"pl\">+</span></button><div class=\"faq-a\">Orders are processed quickly and typically arrive within a few days. You'll see an estimate at checkout.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"skFaq(this)\">Can I pay cash on delivery? <span class=\"pl\">+</span></button><div class=\"faq-a\">Yes — cash on delivery is available. You only pay when your order arrives.</div></div>\n    </div>\n  </div></section>\n\n\n  {%- if p -%}\n  <div class=\"sticky\" id=\"sk-sticky\"><div class=\"sticky-in\">\n    <div><span class=\"sn\">{{ p.title }}<span class=\"sp\" id=\"sk-sprice\">{{ cur.price | money }}</span></span></div>\n    <button type=\"submit\" form=\"sk-form\" class=\"btn\">Add to Cart</button>\n  </div></div>\n  {%- endif -%}\n\n  <div class=\"cd-ov\" id=\"sk-cd-ov\" onclick=\"skCartClose()\"></div>\n  <aside class=\"cd\" id=\"sk-cd\" aria-label=\"Cart\">\n    <div class=\"cd-head\"><h3>Cart (<span id=\"sk-cd-count\">{{ cart.item_count }}</span>)</h3><button class=\"cd-close\" onclick=\"skCartClose()\">×</button></div>\n    <div class=\"cd-items\" id=\"sk-cd-items\"></div><div class=\"cd-foot\" id=\"sk-cd-foot\"></div>\n  </aside>\n\n</div>\n\n<script>\n(function(){\n  var COUNTDOWN_HOURS = 12;\n  function fmt(c){ return \"$\"+(c/100).toFixed(2); }\n  window.skSwap=function(src,el){ document.getElementById(\"sk-main\").src=src; el.parentNode.querySelectorAll(\"img\").forEach(function(i){i.classList.remove(\"active\");}); el.classList.add(\"active\"); };\n  window.skQty=function(d){ var i=document.getElementById(\"sk-qty\"); i.value=Math.max(1,(parseInt(i.value)||1)+d); };\n  var sel=document.getElementById(\"sk-sel\");\n  window.skOpt=function(el,gi){\n    el.parentNode.querySelectorAll(\".swatch\").forEach(function(s){s.classList.remove(\"active\");}); el.classList.add(\"active\");\n    if(!sel) return;\n    var groups=document.querySelectorAll(\"#sk .swatches\"),chosen=[];\n    groups.forEach(function(g){var a=g.querySelector(\".swatch.active\");chosen.push(a?a.getAttribute(\"data-value\"):null);});\n    for(var i=0;i<sel.options.length;i++){\n      var ok=true;\n      for(var k=0;k<chosen.length;k++){ if(chosen[k]&&sel.options[i].getAttribute(\"data-opt\"+k)!==chosen[k]){ok=false;break;} }\n      if(ok){ sel.selectedIndex=i; var pr=sel.options[i].getAttribute(\"data-price\"),dis=sel.options[i].disabled;\n        document.getElementById(\"sk-price\").textContent=pr; var sp=document.getElementById(\"sk-sprice\"); if(sp) sp.textContent=pr;\n        var b=document.getElementById(\"sk-atc\"); if(b){ b.disabled=dis; b.textContent=dis?\"Sold Out\":\"Add to Cart\"; } break; }\n    }\n  };\n  window.skFaq=function(b){ b.parentNode.classList.toggle(\"open\"); };\n  (function(){\n    var hEl=document.getElementById(\"sk-cd-h\"),mEl=document.getElementById(\"sk-cd-m\"),sEl=document.getElementById(\"sk-cd-s\"); if(!hEl) return;\n    var key=\"sk-deadline\",dl=parseInt(localStorage.getItem(key));\n    if(!dl||isNaN(dl)||dl<Date.now()){ dl=Date.now()+COUNTDOWN_HOURS*3600*1000; localStorage.setItem(key,dl); }\n    function pad(n){ return n<10?\"0\"+n:\"\"+n; }\n    function tick(){ var diff=Math.max(0,dl-Date.now()),s=Math.floor(diff/1000);\n      hEl.textContent=pad(Math.floor(s/3600)); mEl.textContent=pad(Math.floor(s%3600/60)); sEl.textContent=pad(s%60);\n      if(diff<=0){ dl=Date.now()+COUNTDOWN_HOURS*3600*1000; localStorage.setItem(key,dl); } }\n    tick(); setInterval(tick,1000);\n  })();\n  var atc=document.getElementById(\"sk-atc\"),sticky=document.getElementById(\"sk-sticky\");\n  if(atc&&sticky){ window.addEventListener(\"scroll\",function(){ var r=atc.getBoundingClientRect(); sticky.classList.toggle(\"show\",r.bottom<0); },{passive:true}); }\n  var ov=document.getElementById(\"sk-cd-ov\"),cd=document.getElementById(\"sk-cd\"),itemsEl=document.getElementById(\"sk-cd-items\"),footEl=document.getElementById(\"sk-cd-foot\");\n  function render(cart){\n    document.getElementById(\"sk-cd-count\").textContent=cart.item_count;\n    var hc=document.getElementById(\"sk-count\"); if(hc) hc.textContent=cart.item_count;\n    if(cart.item_count===0){ itemsEl.innerHTML='<div class=\"cd-empty\"><p>Your cart is empty.</p></div>'; footEl.innerHTML=\"\"; return; }\n    var h=\"\";\n    cart.items.forEach(function(it,i){\n      h+='<div class=\"cd-item\"><img src=\"'+(it.image?it.image.replace(/(\\.[a-z]+)(\\?|$)/i,\"_140x$1$2\"):\"\")+'\" alt=\"\">'\n       +'<div style=\"flex:1;min-width:0\"><a class=\"cd-title\" href=\"'+it.url+'\">'+it.product_title+'</a>'\n       +(it.variant_title?'<div style=\"font-size:12px;color:#B7A6A2\">'+it.variant_title+'</div>':'')\n       +'<div class=\"cd-qty\"><button onclick=\"skCartChange('+(i+1)+','+(it.quantity-1)+')\">−</button><span>'+it.quantity+'</span><button onclick=\"skCartChange('+(i+1)+','+(it.quantity+1)+')\">+</button></div>'\n       +'<button class=\"cd-rm\" onclick=\"skCartChange('+(i+1)+',0)\">Remove</button></div>'\n       +'<div style=\"font-family:Cormorant Garamond,serif;font-size:18px;color:#3E2F33;flex-shrink:0\">'+fmt(it.final_line_price)+'</div></div>';\n    });\n    itemsEl.innerHTML=h;\n    footEl.innerHTML='<div class=\"cd-sub\"><span>Subtotal</span><b>'+fmt(cart.total_price)+'</b></div><p style=\"font-size:11px;letter-spacing:1px;color:#B7A6A2;margin:0 0 8px\">Cash on delivery · taxes at checkout.</p><a class=\"cd-co\" href=\"/checkout\">Checkout</a>';\n  }\n  function refresh(){ fetch(\"/cart.js\").then(function(r){return r.json();}).then(render); }\n  window.skCartOpen=function(){ ov.classList.add(\"open\"); cd.classList.add(\"open\"); document.body.style.overflow=\"hidden\"; refresh(); };\n  window.skCartClose=function(){ ov.classList.remove(\"open\"); cd.classList.remove(\"open\"); document.body.style.overflow=\"\"; };\n  window.skCartChange=function(line,qty){ fetch(\"/cart/change.js\",{method:\"POST\",headers:{\"Content-Type\":\"application/json\"},body:JSON.stringify({line:line,quantity:qty})}).then(function(r){return r.json();}).then(render); };\n  document.addEventListener(\"submit\",function(e){ if(e.target.id===\"sk-form\"){ e.preventDefault(); fetch(\"/cart/add.js\",{method:\"POST\",body:new FormData(e.target)}).then(function(r){return r.json();}).then(function(){ skCartOpen(); }); } });\n  refresh();\n})();\n</script>"
      }
    },
    "section_liquid_hchChA": {
      "type": "section-liquid",
      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "{%- comment -%} ══════════════════════════════════════════════\n  SILKARA — TRUST TRIO SECTION + FOOTER (standalone)\n  Drop these two blocks anywhere you need them.\n  Requires the #sk CSS variables to be loaded on the page.\n══════════════════════════════════════════════ {%- endcomment -%}\n\n{%- comment -%} ── SECTION: Trust Trio (the section just before the footer) ── {%- endcomment -%}\n<section class=\"sect\" id=\"sk-trust\"><div class=\"wrap\"><div class=\"trio\">\n  <div class=\"ti\"><div class=\"ico\">🌸</div><h3>Gentle &amp; Effective</h3><p>Kind, thoughtfully chosen formulas that work.</p></div>\n  <div class=\"ti\"><div class=\"ico\">✦</div><h3>Quietly Luxurious</h3><p>Beautiful essentials that feel as good as they look.</p></div>\n  <div class=\"ti\"><div class=\"ico\">💌</div><h3>Easy &amp; Trusted</h3><p>Cash on delivery and friendly support.</p></div>\n</div></div></section>\n\n{%- comment -%} ── FOOTER ── {%- endcomment -%}\n<footer class=\"ft\" id=\"sk-footer\"><div class=\"wrap\">\n  <div class=\"ft-grid\">\n    <div>\n      <div class=\"name\">SILKARA</div>\n      <p class=\"tag\">Premium skincare &amp; haircare essentials, thoughtfully chosen and delivered to your door.</p>\n    </div>\n    <div>\n      <h4>Shop</h4>\n      <ul>\n        <li><a href=\"{{ routes.all_products_collection_url }}\">All Products</a></li>\n        {%- assign p = product | default: collections.all.products.first -%}\n        {%- if p -%}<li><a href=\"{{ p.url }}\">{{ p.title | truncate: 24 }}</a></li>{%- endif -%}\n      </ul>\n    </div>\n    <div>\n      <h4>Help</h4>\n      <ul>\n        <li><a href=\"/pages/contact\">Contact</a></li>\n        <li><a href=\"/pages/shipping\">Shipping</a></li>\n        <li><a href=\"/pages/returns\">Returns</a></li>\n        <li><a href=\"/pages/about\">About</a></li>\n      </ul>\n    </div>\n  </div>\n  <div class=\"ft-bottom\">\n    <p>© {{ 'now' | date: '%Y' }} Silkara · Skin &amp; Hair</p>\n    <span class=\"cod\">Cash on Delivery available</span>\n  </div>\n</div></footer>\n\n{%- comment -%} ══ Scoped styles — only needed if NOT using the full product page template ══ {%- endcomment -%}\n<style>\n  /* Only include this <style> block if you're NOT using the full product page template.\n     If the full template is already loaded, these are already covered. */\n  :root {\n    --bg:#FFFFFF; --cream:#FBF3F1; --blush:#F6E6E3; --accent:#B26E73; --accent2:#CDA0A0;\n    --ink:#3E2F33; --text:#6E5F62; --line:#EEE0DC; --foot:#3E2F33;\n    --serif:'Cormorant Garamond',Georgia,'Times New Roman',serif;\n    --sans:'Jost',-apple-system,BlinkMacSystemFont,\"Segoe UI\",sans-serif;\n  }\n\n  /* Trust Trio */\n  #sk-trust { padding:90px 0; background:#FFFFFF; }\n  #sk-trust .wrap { max-width:1280px; margin:0 auto; padding:0 40px; box-sizing:border-box; }\n  #sk-trust .trio { display:grid; grid-template-columns:repeat(3,1fr); gap:50px; }\n  #sk-trust .ti { text-align:center; min-width:0; box-sizing:border-box; }\n  #sk-trust .ti .ico { font-size:28px; margin-bottom:14px; }\n  #sk-trust .ti h3 { font-family:var(--serif); font-size:21px; font-weight:500; margin:0 0 6px; color:var(--ink); }\n  #sk-trust .ti p { font-size:14px; color:var(--text); margin:0; max-width:260px; margin-inline:auto; font-family:var(--sans); font-weight:300; line-height:1.7; }\n\n  /* Footer */\n  #sk-footer { background:var(--foot); color:#F1E6E3; padding:70px 0 0; font-family:var(--sans); font-weight:300; box-sizing:border-box; width:100%; }\n  #sk-footer *, #sk-footer *::before, #sk-footer *::after { box-sizing:border-box; }\n  #sk-footer .wrap { max-width:1280px; margin:0 auto; padding:0 40px; }\n  #sk-footer a { color:#F1E6E3; text-decoration:none; opacity:.78; }\n  #sk-footer a:hover { opacity:1; }\n  #sk-footer .ft-grid { display:grid; grid-template-columns:1.6fr 1fr 1fr; gap:48px; padding-bottom:50px; }\n  #sk-footer .ft-grid > * { min-width:0; }\n  #sk-footer .name { font-family:var(--serif); font-size:28px; font-weight:500; letter-spacing:6px; text-indent:6px; color:#fff; }\n  #sk-footer .tag { opacity:.7; font-size:14px; max-width:320px; margin-top:14px; color:#D8C7C3; line-height:1.7; }\n  #sk-footer h4 { font-size:11px; font-weight:500; text-transform:uppercase; letter-spacing:2.5px; margin:0 0 18px; color:#fff; font-family:var(--sans); }\n  #sk-footer ul { list-style:none; padding:0; margin:0; }\n  #sk-footer li { margin-bottom:12px; font-size:14px; }\n  #sk-footer .ft-bottom { border-top:1px solid rgba(255,255,255,.12); padding:24px 0; display:flex; flex-wrap:wrap; gap:14px; justify-content:space-between; align-items:center; }\n  #sk-footer .ft-bottom p { margin:0; font-size:12px; letter-spacing:1px; opacity:.55; color:#D8C7C3; }\n  #sk-footer .cod { font-size:11px; letter-spacing:2px; text-transform:uppercase; opacity:.7; color:#F1E6E3; }\n\n  /* Responsive */\n  @media(max-width:860px) {\n    #sk-trust .wrap, #sk-footer .wrap { padding:0 20px; }\n    #sk-footer .ft-grid { grid-template-columns:1fr 1fr; }\n  }\n  @media(max-width:760px) {\n    #sk-trust .trio { grid-template-columns:1fr; gap:36px; }\n    #sk-footer .ft-grid { grid-template-columns:1fr; }\n  }\n</style>"
      }
    }
